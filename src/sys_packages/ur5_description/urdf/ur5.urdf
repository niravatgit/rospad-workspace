<?xml version="1.0"?>
<robot name="ur5">

  <!-- ══ LINKS ══ -->
  <link name="world"/>

  <link name="base_link"/>

  <link name="base_link_inertia">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 3.14159265358979"/>
      <geometry><mesh filename="package://ur5_description/meshes/visual/base.glb"/></geometry>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 3.14159265358979"/>
      <geometry><mesh filename="package://ur5_description/meshes/visual/base.dae"/></geometry>
    </collision>
    <inertial>
      <mass value="4.0"/>
      <origin xyz="0 0 0"/>
      <inertia ixx="0.00443333156" ixy="0.0" ixz="0.0"
               iyy="0.00443333156" iyz="0.0" izz="0.0075"/>
    </inertial>
  </link>

  <link name="shoulder_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 3.14159265358979"/>
      <geometry><mesh filename="package://ur5_description/meshes/visual/shoulder.glb"/></geometry>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 3.14159265358979"/>
      <geometry><mesh filename="package://ur5_description/meshes/visual/shoulder.dae"/></geometry>
    </collision>
    <inertial>
      <mass value="3.7"/>
      <origin xyz="0 0 0"/>
      <inertia ixx="0.010267495893" ixy="0.0" ixz="0.0"
               iyy="0.010267495893" iyz="0.0" izz="0.00666"/>
    </inertial>
  </link>

  <link name="upper_arm_link">
    <visual>
      <origin xyz="0 0 0.13585" rpy="1.5707963267948966 0 -1.5707963267948966"/>
      <geometry><mesh filename="package://ur5_description/meshes/visual/upperarm.glb"/></geometry>
    </visual>
    <collision>
      <origin xyz="0 0 0.13585" rpy="1.5707963267948966 0 -1.5707963267948966"/>
      <geometry><mesh filename="package://ur5_description/meshes/visual/upperarm.dae"/></geometry>
    </collision>
    <inertial>
      <mass value="8.393"/>
      <origin xyz="0 0 0.28"/>
      <inertia ixx="0.1338857818623325" ixy="0.0" ixz="0.0"
               iyy="0.1338857818623325" iyz="0.0" izz="0.0151074"/>
    </inertial>
  </link>

  <link name="forearm_link">
    <visual>
      <origin xyz="0 0 0.0165" rpy="1.5707963267948966 0 -1.5707963267948966"/>
      <geometry><mesh filename="package://ur5_description/meshes/visual/forearm.glb"/></geometry>
    </visual>
    <collision>
      <origin xyz="0 0 0.0165" rpy="1.5707963267948966 0 -1.5707963267948966"/>
      <geometry><mesh filename="package://ur5_description/meshes/visual/forearm.dae"/></geometry>
    </collision>
    <inertial>
      <mass value="2.275"/>
      <origin xyz="0 0 0.25"/>
      <inertia ixx="0.031209355099586" ixy="0.0" ixz="0.0"
               iyy="0.031209355099586" iyz="0.0" izz="0.004095"/>
    </inertial>
  </link>

  <link name="wrist_1_link">
    <visual>
      <origin xyz="0 0 -0.093" rpy="1.5707963267948966 0 0"/>
      <geometry><mesh filename="package://ur5_description/meshes/visual/wrist1.glb"/></geometry>
    </visual>
    <collision>
      <origin xyz="0 0 -0.093" rpy="1.5707963267948966 0 0"/>
      <geometry><mesh filename="package://ur5_description/meshes/visual/wrist1.dae"/></geometry>
    </collision>
    <inertial>
      <mass value="1.219"/>
      <origin xyz="0 0 0"/>
      <inertia ixx="0.0025598989760729" ixy="0.0" ixz="0.0"
               iyy="0.0025598989760729" iyz="0.0" izz="0.0021942"/>
    </inertial>
  </link>

  <link name="wrist_2_link">
    <visual>
      <origin xyz="0 0 -0.095" rpy="0 0 0"/>
      <geometry><mesh filename="package://ur5_description/meshes/visual/wrist2.glb"/></geometry>
    </visual>
    <collision>
      <origin xyz="0 0 -0.095" rpy="0 0 0"/>
      <geometry><mesh filename="package://ur5_description/meshes/visual/wrist2.dae"/></geometry>
    </collision>
    <inertial>
      <mass value="1.219"/>
      <origin xyz="0 0 0"/>
      <inertia ixx="0.0025598989760729" ixy="0.0" ixz="0.0"
               iyy="0.0025598989760729" iyz="0.0" izz="0.0021942"/>
    </inertial>
  </link>

  <link name="wrist_3_link">
    <visual>
      <origin xyz="0 0 -0.0818" rpy="1.5707963267948966 0 0"/>
      <geometry><mesh filename="package://ur5_description/meshes/visual/wrist3.glb"/></geometry>
    </visual>
    <collision>
      <origin xyz="0 0 -0.0818" rpy="1.5707963267948966 0 0"/>
      <geometry><mesh filename="package://ur5_description/meshes/visual/wrist3.dae"/></geometry>
    </collision>
    <inertial>
      <mass value="0.1879"/>
      <origin xyz="0 0 0"/>
      <inertia ixx="9.890410052167399e-05" ixy="0.0" ixz="0.0"
               iyy="9.890410052167399e-05" iyz="0.0" izz="0.000132"/>
    </inertial>
  </link>

  <link name="tool0"/>
  <link name="ee_link"/>

  <!-- ══ JOINTS ══ -->

  <joint name="world_joint" type="fixed">
    <parent link="world"/>
    <child  link="base_link"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>

  <!-- Fixed joint: base_link → base_link_inertia (π rotation around Z) -->
  <joint name="base_link-base_link_inertia" type="fixed">
    <parent link="base_link"/>
    <child  link="base_link_inertia"/>
    <origin xyz="0 0 0" rpy="0 0 3.14159265358979"/>
  </joint>

  <!-- J0: shoulder pan — rotates around Z, mount height 0.089159 m -->
  <joint name="shoulder_pan_joint" type="revolute">
    <parent link="base_link_inertia"/>
    <child  link="shoulder_link"/>
    <origin xyz="0 0 0.089159" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-6.2831853" upper="6.2831853" effort="150" velocity="3.15"/>
    <dynamics damping="0.0" friction="0.0"/>
  </joint>

  <!-- J1: shoulder lift — rotates around Y, joint pre-rotated π/2 around Y -->
  <joint name="shoulder_lift_joint" type="revolute">
    <parent link="shoulder_link"/>
    <child  link="upper_arm_link"/>
    <origin xyz="0 0.13585 0" rpy="0 1.5707963267948966 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-6.2831853" upper="6.2831853" effort="150" velocity="3.15"/>
    <dynamics damping="0.0" friction="0.0"/>
  </joint>

  <!-- J2: elbow — rotates around Y -->
  <joint name="elbow_joint" type="revolute">
    <parent link="upper_arm_link"/>
    <child  link="forearm_link"/>
    <origin xyz="0 -0.1197 0.425" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-3.1415926" upper="3.1415926" effort="150" velocity="3.15"/>
    <dynamics damping="0.0" friction="0.0"/>
  </joint>

  <!-- J3: wrist 1 — rotates around Y, joint pre-rotated π/2 around Y -->
  <joint name="wrist_1_joint" type="revolute">
    <parent link="forearm_link"/>
    <child  link="wrist_1_link"/>
    <origin xyz="0 0 0.39225" rpy="0 1.5707963267948966 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-6.2831853" upper="6.2831853" effort="28" velocity="3.2"/>
    <dynamics damping="0.0" friction="0.0"/>
  </joint>

  <!-- J4: wrist 2 — rotates around Z -->
  <joint name="wrist_2_joint" type="revolute">
    <parent link="wrist_1_link"/>
    <child  link="wrist_2_link"/>
    <origin xyz="0 0.093 0" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-6.2831853" upper="6.2831853" effort="28" velocity="3.2"/>
    <dynamics damping="0.0" friction="0.0"/>
  </joint>

  <!-- J5: wrist 3 — rotates around Y -->
  <joint name="wrist_3_joint" type="revolute">
    <parent link="wrist_2_link"/>
    <child  link="wrist_3_link"/>
    <origin xyz="0 0 0.09465" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-6.2831853" upper="6.2831853" effort="28" velocity="3.2"/>
    <dynamics damping="0.0" friction="0.0"/>
  </joint>

  <joint name="wrist_3-tool0" type="fixed">
    <parent link="wrist_3_link"/>
    <child  link="tool0"/>
    <origin xyz="0 0.0823 0" rpy="1.5707963267948966 0 0"/>
  </joint>

  <joint name="wrist_3-ee_link" type="fixed">
    <parent link="wrist_3_link"/>
    <child  link="ee_link"/>
    <origin xyz="0 0.0823 0" rpy="0 0 0"/>
  </joint>

</robot>
